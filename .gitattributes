# Git 属性规则
# 详见：https://git-scm.com/docs/gitattributes
# 目标：统一文本文件行尾为 LF，避免跨平台 LF/CRLF 漂移噪音

# === 默认：文本自动识别，签出时统一 LF ===
* text=auto eol=lf

# === Windows 专属脚本：保留 CRLF ===
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# === Godot / GDScript 文本资源：LF ===
*.gd        text eol=lf
*.tscn      text eol=lf
*.tres      text eol=lf
*.gdshader  text eol=lf
*.gdignore  text eol=lf
*.cfg       text eol=lf
*.godot     text eol=lf

# === 通用文本：LF ===
*.md        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.svg       text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig  text eol=lf

# === Shell 脚本：LF ===
*.sh        text eol=lf

# === 二进制资源：标记为 binary，禁止行尾归一化 ===
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.bmp       binary
*.ogg       binary
*.wav       binary
*.mp3       binary
*.flac      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.aseprite  binary
*.blend     binary
*.fbx       binary
*.glb       binary
*.gltf      binary
*.bin       binary
*.zip       binary
*.import    binary

# === linguist 语言识别（GitHub 统计） ===
*.gd        linguist_language=GDScript
*.tscn      linguist_language=GDScript
*.tres      linguist_language=GDScript
