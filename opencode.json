{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "AGENTS.md"
    ],
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama (local)",
            "options": {
                "baseURL": "http://localhost:11434/v1"
            },
            "models": {
                "gemma4:12b": {
                    "name": "gemma4:12b"
                }
            }
        }
    },
    "permission": {
        "skill": "allow",
        "bash": "allow",
        "external_directory": {
            "*": "allow"
        }
    },
    "mcp": {
        "godot-mcp": {
            "type": "local",
            "command": [
                "npx",
                "@coding-solo/godot-mcp"
            ],
            "environment": {
                "DEBUG": "false",
                "GODOT_PATH": "{env:GODOT_HOME}"
            }
        },
        "minimal-godot": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@ryanmazzolini/minimal-godot-mcp"
            ],
            "environment": {
                "GODOT_LSP_PORT": "6005",
                "GODOT_WORKSPACE_PATH": "{env:WORKSPACE_HOME}/code/07_games/GodotScaffolding"
            }
        },
        "godot-ultimate": {
            "type": "local",
            "command": [
                "node",
                "{env:WORKSPACE_HOME}/code/01_AI/godot-mcp-ultimate/dist/index.js"
            ],
            "environment": {
                "GODOT_PROJECT_PATH": "{env:WORKSPACE_HOME}/code/07_games/GodotScaffolding",
                "GODOT_PATH": "{env:GODOT_HOME}",
                "GODOT_LSP_PORT": "6005"
            }
        },
        "filesystem": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "{env:WORKSPACE_HOME}/code/07_games/GodotScaffolding"
            ]
        },
        "aseprite": {
            "type": "local",
            "command": [
                "uv",
                "--directory",
                "{env:WORKSPACE_HOME}/code/07_games/aseprite-mcp",
                "run",
                "-m",
                "aseprite_mcp"
            ],
            "environment": {
                "ASEPRITE_PATH": "{env:ASEPRITE_PATH}"
            },
            "enabled": true,
            "timeout": 30000
        }
    }
}