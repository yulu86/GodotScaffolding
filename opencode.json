{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "AGENTS.md",
        "CONSTITUTION.md"
    ],
    "permission": {
        "skill": {
            "brainstorming": "allow",
            "caveman": "allow",
            "dispatching-parallel-agents": "allow",
            "executing-plans": "allow",
            "find-skills": "allow",
            "finishing-a-development-branch": "allow",
            "frontend-design": "allow",
            "grill-me": "allow",
            "handoff": "allow",
            "mcp-builder": "allow",
            "receiving-code-review": "allow",
            "requesting-code-review": "allow",
            "skill-creator": "allow",
            "skill-vetter": "allow",
            "subagent-driven-development": "allow",
            "summarize": "allow",
            "systematic-debugging": "allow",
            "test-driven-development": "allow",
            "using-git-worktrees": "allow",
            "using-superpowers": "allow",
            "verification-before-completion": "allow",
            "write-a-skill": "allow",
            "writing-plans": "allow",
            "writing-skills": "allow",
            "godot-architect": "allow",
            "godot-best-practices": "allow",
            "godot-gdscript-patterns": "allow",
            "godot-ui": "allow",
            "godot-code-review": "allow",
            "sprite-analyzer": "allow",
            "*": "ask"
        }
    },
    "mcp": {
        "godot-mcp": {
            "type": "local",
            "command": [
                "npx",
                "@coding-solo/godot-mcp"
            ],
            "environment": {
                "DEBUG": "false",
                "GODOT_PATH": "{env:GODOT_HOME}"
            }
        },
        "minimal-godot": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@ryanmazzolini/minimal-godot-mcp"
            ],
            "environment": {
                "GODOT_LSP_PORT": "6005",
                "GODOT_WORKSPACE_PATH": "{env:WORKSPACE_HOME}/code/07_games/brave-legend"
            }
        },
        "godot-ultimate": {
            "type": "local",
            "command": [
                "node",
                "{env:WORKSPACE_HOME}/code/01_AI/godot-mcp-ultimate/dist/index.js"
            ],
            "environment": {
                "GODOT_PROJECT_PATH": "{env:WORKSPACE_HOME}/code/07_games/brave-legend",
                "GODOT_PATH": "{env:GODOT_HOME}",
                "GODOT_LSP_PORT": "6005"
            }
        },
        "filesystem": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "{env:WORKSPACE_HOME}/code/07_games/brave-legend"
            ]
        },
        "pencil": {
            "type": "local",
            "command": [
                "{env:PENCIL_PATH}",
                "--app",
                "visual_studio_code"
            ]
        }
    }
}
